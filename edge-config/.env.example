# Edge Agent Environment Variables

# Mothership URL (update with your fly.io deployment URL)
MOTHERSHIP_URL=https://goldclaw-mothership.fly.dev

# Agent ID (unique per edge device)
AGENT_ID=agent-demo-001

# Agent Secret (HMAC signing key - generate a secure random string)
AGENT_SECRET=your-secure-random-secret-here

# Additional env variables available to WASM tools
# TOOL_GITHUB_TOKEN=ghp_xxxx  (for git_clone tool)
# TOOL_S3_BUCKET=my-bucket     (for file upload tools)
